    "\n",
    "# 1. 分词函数（结合停用词过滤）\n",
    "def tokenize(text, stopwords):\n",
    "    words = jieba.lcut(text)  # 精确模式分词\n",
    "    return [word for word in words if word not in stopwords and len(word) > 1]  # 去停用词和单字\n",
    "\n",
    "# 2. 对清洗后的文本进行分词\n",
    "df['tokens'] = df['clean'].apply(lambda x: tokenize(x, cn_stop))\n",
    "\n",
    "# 3. 统计高频词（示例：按评价类别分组统计）\n",
    "def get_top_keywords(data, top_n=20):\n",
    "    all_words = [word for tokens in data['tokens'] for word in tokens]\n",
    "    return Counter(all_words).most_common(top_n)\n",
    "\n",
