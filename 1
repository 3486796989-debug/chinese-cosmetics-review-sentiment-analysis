    "# 对数据集文本内容的分析可知，其中存在大量html关键字，需要去除这部分对人类阅读无意义的词\n",
    "HTML_ENTS_PATTERN = re.compile(r'&[a-z]{2,7};')\n",
    "# 特殊字符\n",
    "TAG_PATTERN= re.compile(r'<[^>]+>')\n",
    "\n",
    "def clean_text(txt):\n",
    "    if not isinstance(txt, str) or not txt.strip():\n",
    "        return \"\"\n",
    "    # 尝试解码html实体\n",
    "    txt = html.unescape(txt)\n",
    "    # 去除html标签\n",
    "    txt = TAG_PATTERN.sub(\" \", txt)\n",
    "    # 去除残留的html关键字\n",
    "    txt = HTML_ENTS_PATTERN.sub(\" \", txt)\n",
    "    # 4. 非中英文数字替换为空格\n",
    "    txt = re.sub(r\"[^\\w\\u4e00-\\u9fa5]+\", \" \", txt)\n",
    "    txt = re.sub(r'\\s+', ' ', txt)\n",
    "    return txt.strip()\n",
    "\n",
    "df['clean'] = df['text'].apply(clean_text)\n",
    "print(df[\"text\"].head())\n",
    "print('去除特殊字符以及符号')\n",
