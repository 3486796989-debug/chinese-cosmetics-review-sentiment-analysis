    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "\n",
    "def auto_stopword_detection(nb_model, tfidf, X_train_tfidf):\n",
    "    \"\"\"\n",
    "    全自动停用词检测（无人工参数）\n",
    "    返回:\n",
    "        - 停用词候选表（DataFrame）\n",
    "        - 推荐保留的关键词表\n",
    "    \"\"\"\n",
    "    # 获取模型内部特征权重\n",
    "    log_prob = nb_model.feature_log_prob_\n",
    "    feature_names = tfidf.get_feature_names_out()\n",
    "    \n",
    "    # 计算自动阈值（基于数据分布）\n",
    "    weight_diffs = np.abs(log_prob[1] - log_prob[0])\n",
    "    auto_diff_thresh = np.percentile(weight_diffs, 15)  # 取差异最小的15%\n",
    "    \n",
    "    # 构建词统计表\n",
    "    df = pd.DataFrame({\n",
    "        'word': feature_names,\n",
    "        'freq': np.asarray(X_train_tfidf.sum(axis=0)).flatten(),\n",
    "        'good_weight': log_prob[0],\n",
    "        'bad_weight': log_prob[1],\n",
    "        'weight_diff': weight_diffs\n",
    "    })\n",
    "    \n",
    "    # 自动识别停用候选词（完全基于数据分布）\n",
    "    df['is_stop_candidate'] = df['weight_diff'] < auto_diff_thresh\n",
    "    \n",
    "    # 识别关键保留词（自动）\n",
    "    df['is_keyword'] = (\n",
    "        (df['weight_diff'] > np.percentile(weight_diffs, 75)) |  # 差异大的词\n",
    "        (df[['good_weight', 'bad_weight']].abs().min(axis=1) > 2.0)  # 强情感词\n",
    "    )\n",
    "    \n",
    "    return df, set(df[df['is_stop_candidate'] & ~df['is_keyword']]['word'])\n",
    "\n",
    "# 使用示例\n",
    "stopword_report, recommended_stops = auto_stopword_detection(\n",
    "    nb_model, tfidf, X_train_tfidf)\n",
    "\n",
    "# 打印自动结果\n",
    "print(\"=\"*80)\n",
    "print(\"自动生成的停用词候选表（按词频排序）：\")\n",
    "display(stopword_report[stopword_report['is_stop_candidate']]\n",
    "       .sort_values('freq', ascending=False)\n",
    "       .head(100)[['word', 'freq', 'weight_diff']])\n",
    "\n",
    "print(\"\\n自动识别需保留的关键词（前50个）：\")\n",
    "display(stopword_report[stopword_report['is_keyword']]\n",
    "       .sort_values('weight_diff', ascending=False)\n",
    "       .head(50)[['word', 'freq', 'weight_diff']])\n",
    "\n",
    "# 获取最终停用词\n",
    "final_stopwords = set(stopword_report[\n",
    "    (stopword_report['is_stop_candidate']) & \n",
    "    (~stopword_report['is_keyword'])\n",
    "]['word'])\n",
    "\n",
    "# 打印最终结果\n",
    "print(\"=\"*80)\n",
    "print(f\"【最终确定的停用词数量】: {len(final_stopwords)}\")\n",
