    "        for phrase in POSITIVE_PHRASES:\n",
    "            phrase_words = phrase.split()\n",
    "            if words[i:i+len(phrase_words)] == phrase_words:\n",
    "                merged.append(phrase.replace(' ', ''))\n",
    "                i += len(phrase_words)\n",
    "                break\n",
    "        else:\n",
    "            # 情况2：处理否定短语（排除正面场景）\n",
