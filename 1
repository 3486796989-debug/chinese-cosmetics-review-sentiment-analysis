    "    NEGATION_WORDS = {'不', '没', '无', '非', '未', '毫无', '完全不'}\n",
    "    POSITIVE_PHRASES = {  # 新增正面评价短语\n",
    "        '服务态度好', '很有耐心', '高端大气', '包装精美', '物超所值',\n",
    "        '物美价廉', '非常满意', '强烈推荐', '会回购', '发货快',\n",
    "        '客服专业', '正品保障', '体验很好'\n",
    "    }\n",
    "    BEAUTY_PHRASES = {\n",
    "        '持妆效果', '控油能力', '哑光质地', '防水防汗',\n",
    "        '玻尿酸', '氨基酸', '防晒系数', '色号'\n",
    "    }\n",
    "    UNIT_PATTERN = re.compile(r'^(\\d+)(小时|天|个月|分钟)$')\n",
    "    ECOMMERCE_PATTERNS = [  # 电商特有表达\n",
    "        r'满\\d+减\\d+', r'赠品', r'京东物流', r'顺丰包邮'\n",
    "    ]\n",
